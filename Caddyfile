{$DOMAIN} {
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
    }

    # Backend REST API
    handle /api/* {
        reverse_proxy backend:3002
    }

    # Backend static uploads
    handle /uploads/* {
        reverse_proxy backend:3002
    }

    # WebSocket (Socket.io) — Caddy upgrades the connection automatically
    handle /socket.io/* {
        reverse_proxy backend:3002
    }

    # Frontend (Next.js) — catch-all
    handle {
        reverse_proxy frontend:3000
    }
}
