{
  "name": "oncosaas-backend",
  "version": "0.1.0",
  "description": "Backend API para Plataforma Oncológica",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:https": "cross-env USE_HTTPS=true nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "verify-dashboard": "ts-node scripts/verify-dashboard-metrics.ts",
    "export-bia": "ts-node scripts/export-bia-conversation.ts",
    "verify-questionnaire": "ts-node scripts/verify-questionnaire-flow.ts",
    "analyze-bia": "ts-node scripts/analyze-bia-conversation.ts",
    "exam-catalog:from-tuss": "python3 scripts/exam-catalog-from-tuss-xlsx.py -i data/ans/CorrelacaoTUSS.202409Rol.2021_TUSS202503_RN627L.2025.xlsx -o data/ans/exam-catalog-import.json --indent 2",
    "exam-catalog:import-json": "ts-node -r tsconfig-paths/register scripts/import-exam-catalog-json.ts",
    "export-protocol-snapshot": "ts-node -r tsconfig-paths/register scripts/export-protocol-snapshot.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/websockets": "^11.1.18",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/ioredis": "^4.28.10",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "facebook-nodejs-business-sdk": "^24.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.37",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "defu": "^6.1.5",
    "lodash": "^4.18.0",
    "picomatch": "^4.0.4",
    "follow-redirects": "^1.16.0",
    "hono": "^4.12.12",
    "@hono/node-server": "^1.19.13"
  }
}
