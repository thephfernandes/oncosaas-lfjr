# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WS_URL=ws://localhost:3002
# WhatsApp OAuth Meta App (required for WhatsApp connection flow)
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_CONFIG_ID=your-meta-config-id

# Backend
NODE_ENV=development
PORT=3002
# Database credentials (override in production — change ONCONAV_dev to a strong password)
POSTGRES_USER=ONCONAV
POSTGRES_PASSWORD=ONCONAV_dev
POSTGRES_DB=ONCONAV_development
DATABASE_URL=postgresql://ONCONAV:ONCONAV_dev@localhost:5432/ONCONAV_development
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ (override passwords in production)
RABBITMQ_DEFAULT_USER=ONCONAV
RABBITMQ_DEFAULT_PASS=ONCONAV_dev
RABBITMQ_URL=amqp://ONCONAV:ONCONAV_dev@localhost:5672

# WhatsApp Business API (Meta OAuth)
META_APP_ID=your-meta-app-id
META_APP_CONFIG_ID=your-meta-config-id
META_APP_SECRET=your-meta-app-secret
# Frontend (NEXT_PUBLIC_ necessário para Next.js client-side) — mesmos valores que META_APP_ID e META_APP_CONFIG_ID
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_CONFIG_ID=your-meta-config-id
META_API_VERSION=v25.0

# Encryption (para criptografar tokens OAuth e credenciais)
ENCRYPTION_KEY=your-32-byte-encryption-key-change-in-production!!

# Frontend URL (para redirecionamentos OAuth e CORS)
FRONTEND_URL=http://localhost:3000

# Embedded Signup (WhatsApp) — único fluxo usado. URL da página que abre o fluxo (ex: /integrations).
# Deve ser idêntica à configurada em "Valid OAuth Redirect URIs" e "Allowed domains" no app Meta (Facebook Login for Business).
# Sem barra final (ex: http://localhost:3000/integrations). Ver docs/desenvolvimento/whatsapp-embedded-signup-config.md
META_EMBEDDED_SIGNUP_REDIRECT_URI=http://localhost:3000/integrations
# Se o app for Tech Provider, a Meta não exige redirect_uri na troca de código. Defina false para omitir.
# META_EMBEDDED_SIGNUP_USE_REDIRECT_URI=false

# CORS: production domains for backend (required in production — comma-separated)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CORS: production domains for ai-service (required in production — comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# WhatsApp Business API (Legacy - se usar configuração manual)
WHATSAPP_API_URL=https://graph.facebook.com/${META_API_VERSION}/
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# LLM APIs
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# STT
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_CREDENTIALS_PATH=./credentials/google-cloud.json

# AWS S3 (para armazenar áudios)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ONCONAV-conversations

# FHIR Integration
FHIR_BASE_URL=https://fhir.example.com
FHIR_CLIENT_ID=your-fhir-client-id
FHIR_CLIENT_SECRET=your-fhir-client-secret

# AI Service
AI_SERVICE_URL=http://localhost:8001
# Token para autenticação interna backend → ai-service (gere com: openssl rand -hex 32)
BACKEND_SERVICE_TOKEN=your-internal-service-token-change-in-production


