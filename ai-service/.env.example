# AI Service (FastAPI)
BACKEND_URL=http://localhost:3002
BACKEND_SERVICE_TOKEN=change-me-internal-service-token
# ENVIRONMENT=staging ou production exige BACKEND_SERVICE_TOKEN (503 se vazio), mesmo sem flag abaixo.
# ENVIRONMENT=development (padrão local) permite endpoints sem token se BACKEND_SERVICE_TOKEN estiver vazio.
# Opcional [C-01]: true/1/yes/on exige token em qualquer ambiente (503 se BACKEND_SERVICE_TOKEN vazio).
AI_SERVICE_REQUIRE_SERVICE_TOKEN=
# SEC-002: chamadas do Nest à observabilidade enviam X-Tenant-Auth (HMAC-SHA256 do tenant com este token).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002

# Optional tuning
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.30
