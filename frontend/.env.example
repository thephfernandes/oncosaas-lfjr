# Frontend (Next.js)
NODE_ENV=development

# Importante: segredos (ex.: JWT_SECRET) existem **apenas** no backend (`backend/.env`).
# O frontend não assina nem verifica JWT; a sessão é validada consultando o backend (ex.: GET /api/v1/auth/profile)
# usando os cookies HttpOnly (`access_token`/`refresh_token`) quando a API roda na mesma origem via BFF.

# API relativa (rewrite /api/v1 → Nest). Padrão recomendado: true (menor superfície XSS vs cookie legível auth_token).
# Quando true: cookies HttpOnly na mesma origem; definir BACKEND_URL. Quando false: chamada direta a NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_RELATIVE_API=true

# Destino do rewrite (Next server → Nest). Docker: http://backend:3002. Local com Nest HTTPS: https://localhost:3002
BACKEND_URL=http://localhost:3002

NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WS_URL=ws://localhost:3002
NEXT_PUBLIC_API_PORT=3002

NEXT_PUBLIC_META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_CONFIG_ID=your-meta-config-id
NEXT_PUBLIC_META_APP_CONFIG_ID=your-meta-config-id

# Produção: hosts extra em connect-src (CSP), separados por espaço (ex.: https://api.tercdn.com)
NEXT_PUBLIC_CSP_CONNECT_EXTRA=

# URL interna do servidor Next.js para o probe de sessão no middleware.
# Padrão: http://localhost:PORT (sempre correto em Docker). Sobrescrever somente se o servidor
# escutar em endereço diferente (ex.: container sem acesso ao loopback).
# INTERNAL_APP_URL=http://localhost:3000
