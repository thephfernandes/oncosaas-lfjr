{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node ./hooks/cursor-hook-runner.cjs cursor-adapter-shell.sh"
      }
    ],
    "beforeReadFile": [
      {
        "command": "node ./hooks/cursor-hook-runner.cjs cursor-before-read.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node ./hooks/cursor-hook-runner.cjs cursor-after-file-edit.sh"
      }
    ]
  }
}
