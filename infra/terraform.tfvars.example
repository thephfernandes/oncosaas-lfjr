aws_region                 = "sa-east-1"
project                    = "oncosaas"
environment                = "prod"
github_repo                = "your-org/oncosaas"
github_branch              = "main"
app_url                    = "https://oncosaas.example.com"
instance_type              = "t4g.large"
db_instance_class          = "db.t4g.medium"
db_allocated_storage_gb    = 50
allow_ssh                  = true
admin_cidr                 = "203.0.113.10/32"
ssh_public_key             = "ssh-ed25519 <your_public_ssh_key>"
